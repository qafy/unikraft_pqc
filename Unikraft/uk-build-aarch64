FROM ubuntu:jammy

ENV DEBIAN_FRONTEND=noninteractive

RUN set -e ;\
    apt-get update -q=2 ;\
    apt-get install -q=2 --yes \
        qemu-system-aarch64 \
        nano \
        bsdmainutils \
        python3 \
        python-is-python3 \
        python3-yaml \
        python3-pytest \
        python3-pytest-xdist \
        pip \
        expect \
        curl \
        flex \
        bison \
        wget \
        patch \
        gdb \
        patch \
        gcc \
        make \
        iproute2 \
        unzip \
        netcat \
        cmake \
        git \
        ninja-build \
        docker.io \
        libncurses-dev ;\
    rm -rf /var/lib/apt/lists/* ;

RUN curl -sSfL https://get.kraftkit.sh > /tmp/install-kraft.sh
RUN chmod a+x /tmp/install-kraft.sh
RUN bash /tmp/install-kraft.sh -y

RUN mkdir /etc/qemu
RUN echo "allow virbr0" > /etc/qemu/bridge.conf

RUN sed -i \
    's/#force_color_prompt=yes/force_color_prompt=yes/g' \
    /root/.bashrc

ARG OPENSSL_TAG=openssl-3.4.1
ARG LIBOQS_TAG=0.12.0
ARG OQSPROVIDER_TAG=0.8.0
ARG INSTALLDIR=/opt/oqssa

# Install patched musl version
WORKDIR /opt

RUN wget https://musl.libc.org/releases/musl-1.2.3.tar.gz && \
    tar xfv musl-1.2.3.tar.gz

WORKDIR /opt/musl-1.2.3

COPY ./Unikraft/patches/getauxval.patch /opt
RUN patch -p1 < /opt/getauxval.patch

RUN ./configure \
    --prefix="${INSTALLDIR}" \
    --syslibdir="${INSTALLDIR}/syslibdir/" &&\
    make -j$(nproc) &&\
    make install

RUN rm -rf /opt/musl-1.2.3 && \
    rm -f  /opt/musl-1.2.3.tar.gz

# Install linux-headers
WORKDIR /opt

RUN wget https://mirrors.edge.kernel.org/pub/linux/kernel/v6.x/linux-6.12.6.tar.xz && \
    tar xfv linux-6.12.6.tar.xz

WORKDIR /opt/linux-6.12.6

RUN make headers ARCH="arm64" && \
    cp -r ./usr/include/* ${INSTALLDIR}/include

RUN rm -rf /opt/linux-6.12.6 && \
    rm -f  /opt/linux-6.12.6.tar.xz

# Install liboqs
WORKDIR /opt

RUN git clone --depth 1 --branch ${LIBOQS_TAG} https://github.com/open-quantum-safe/liboqs

WORKDIR /opt/liboqs/build

RUN cmake .. \
    -DOQS_USE_OPENSSL=OFF \
    -DCMAKE_INSTALL_PREFIX="${INSTALLDIR}" \
    -DCMAKE_C_COMPILER="${INSTALLDIR}/bin/musl-gcc" \
    -DOQS_ALGS_ENABLED="All" &&\
    cmake --build . -- -j$(nproc) &&\
    cmake --install .

RUN rm -rf /opt/liboqs

# Install patched openssl version
WORKDIR /opt

RUN git clone --depth 1 --branch ${OPENSSL_TAG} https://github.com/openssl/openssl.git

WORKDIR /opt/openssl

COPY ./Unikraft/patches/auxv.patch /opt
RUN patch -p1 < /opt/auxv.patch

RUN ./Configure \
		CC="${INSTALLDIR}/bin/musl-gcc" \
		--prefix="${INSTALLDIR}" \
		--openssldir="${INSTALLDIR}/openssldir" \
		--with-rand-seed=getrandom \
		no-async \
		no-docs \
		no-zlib \
		no-comp \
		no-idea \
		no-mdc2 \
		no-rc5 \
		no-ec2m \
		no-ssl3 \
		no-seed \
		no-weak-ssl-ciphers

RUN make -j"$(nproc)" &&\
    make install

RUN rm -rf /opt/openssl

# Install oqs-provider
WORKDIR /opt

RUN git clone --depth 1 --branch ${OQSPROVIDER_TAG} https://github.com/open-quantum-safe/oqs-provider.git

WORKDIR /opt/oqs-provider

ENV liboqs_DIR="${INSTALLDIR}"
ENV OPENSSL_INSTALL="${INSTALLDIR}"
ENV CMAKE_PARAMS="-DOQS_PROVIDER_BUILD_STATIC=ON -DCMAKE_C_COMPILER=${INSTALLDIR}/bin/musl-gcc -DCMAKE_INSTALL_PREFIX=${INSTALLDIR}"

RUN ./scripts/fullbuild.sh

RUN cmake --install _build

RUN rm -rf /opt/oqs-provider

WORKDIR "/workspace"
CMD ["/bin/bash"]

