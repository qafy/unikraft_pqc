menuconfig LIBOQS
	bool "OQS: Post Qantum Secure Cryptography"
	default n
	select LIBNOLIBC if !HAVE_LIBC
	select LIBUKDEBUG
	select LIBUKALLOC

if LIBOQS
config OQSPROVIDER
	bool "Connect OQS to OpenSSL for PQC TLS Connections"
	default y
	select LIBOPENSSL
	select LIBLWIP
	select LWIP_IPV6
	select LIBPOSIX_USER
	select LIBPOSIX_LIBDL
	select LIBSYSCALL_SHIM
	select LIBUKRANDOM
	select LIBUKRANDOM_DEVFS

config LIBOQS_TEST
	bool "Enable unit tests"
	default n
	select LIBUKTEST
endif


